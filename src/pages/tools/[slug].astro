---
import MainLayout from '../../layouts/MainLayout.astro';
import RelatedPosts from '../../components/RelatedPosts.astro';
import { getCollection, render } from 'astro:content';
import { SITE } from '../../lib/site';

export async function getStaticPaths() {
  const tools = await getCollection('tools');

  return tools.map((tool) => ({
    params: {
      slug: tool.slug
    },
    props: {
      tool
    }
  }));
}

const { tool } = Astro.props;

const { Content, headings } = await render(tool);

const tools = await getCollection('tools');

const relatedTools = tools
  .filter((t) => t.slug !== tool.slug)
  .slice(0, 6);



const softwareSchema = {
  "@context": "https://schema.org",

  "@type": "SoftwareApplication",

  name: tool.data.title,

  description: tool.data.description,

  url: SITE.url(`/tools/${tool.slug}/`),

  applicationCategory: "WebApplication",

  operatingSystem: "Any"
};


const breadcrumbs = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: SITE.url("/")
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Tools",
      item: SITE.url("/tools/")
    },
    {
      "@type": "ListItem",
      position: 3,
      name: tool.data.title,
      item: SITE.url(`/tools/${tool.slug}`)
    }
  ]
};
---

<MainLayout
  title={`${tool.data.title} | ${SITE.title}`}
  description={tool.data.description}
  slug={tool.slug}
  breadcrumbs={breadcrumbs}
  amp={SITE.url(`/tools/${tool.slug}/amp/`)}
>

  <section class="tools-page">
    <div class="container">

<nav class="breadcrumb">
  <a href="/">Home</a>
  <span>/</span>
  <a href="/tools/">Tools</a>
  <span>/</span>
  <span>{tool.data.title}</span>
</nav>

  <article class="tool-content">

    <h1>{tool.data.title}</h1>

    {tool.data.description && (
      <p class="tool-description">
        {tool.data.description}
      </p>
    )}



{headings.length > 0 && (
  <details class="toc">
    <summary>📑 Daftar Isi</summary>

    <ul>
      {headings.map((heading) => (
        <li>
          <a href={`#${heading.slug}`}>
            {heading.text}
          </a>
        </li>
      ))}
    </ul>

  </details>
)}


    <Content />

  </article>

  <RelatedPosts
    posts={relatedTools}
    title="Tools Terkait"
    baseUrl="/tools"
  />
</div>
</section>
</MainLayout>

<style>

.breadcrumb{
  display:flex;
  flex-wrap:wrap;
  gap:.5rem;
  margin-bottom:2rem;
  font-size:.9rem;
}

.breadcrumb a{
  text-decoration:none;
}

.toc{
  margin-bottom:2rem;
  padding:1rem;
  border:1px solid #e5e7eb;
  border-radius:12px;
}

.toc ul{
  margin-top:1rem;
  padding-left:1.25rem;
}

.toc li{
  margin:.4rem 0;
}

.tool-content{
  max-width:900px;
  margin:0 auto;
  padding:2rem 1rem;
}

.tool-content h1{
  margin-bottom:1rem;
}

.tool-description{
  margin-bottom:2rem;
  color:var(--text-soft);
}
</style>

<style>
  .tools-page {
    padding: 4rem 1rem;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .page-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .page-header h1 {
    font-size: 2.5rem;
    margin-bottom: 0.75rem;
  }

  .page-header p {
    color: #666;
    max-width: 600px;
    margin: 0 auto;
  }

  .tools-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .tool-card {
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 16px;
    padding: 1.5rem;
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease;
  }

  .tool-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
  }

  .tool-card h2 {
    margin: 0 0 0.75rem;
    font-size: 1.25rem;
  }

  .tool-card h2 a {
    color: inherit;
    text-decoration: none;
  }

  .tool-card h2 a:hover {
    color: var(--accent-color, #2563eb);
  }

  .tool-card p {
    color: #666;
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  .tool-button {
    display: inline-block;
    text-decoration: none;
    font-weight: 600;
  }

  @media (max-width: 768px) {
    .page-header h1 {
      font-size: 2rem;
    }

    .tools-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
