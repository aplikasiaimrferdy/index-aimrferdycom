---
import MainLayout from '../layouts/MainLayout.astro';
import { SITE } from '../lib/site';
import "../styles/blog.css";

import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const tools = await getCollection('tools');
const products = await getCollection('product');

/* LATEST ARTICLES */

const latestPosts = [...posts]
  .sort(
    (a, b) =>
      new Date(b.data.date) -
      new Date(a.data.date)
  )
  .slice(0, 3);

/* POPULAR ARTICLES */

const popularPosts =
  posts.filter(post => post.data.popular).length > 0
    ? posts
        .filter(post => post.data.popular)
        .slice(0, 3)
    : posts.slice(0, 3);

/* POPULAR TOOLS */

const popularTools =
  tools.filter(tool => tool.data.popular).length > 0
    ? tools
        .filter(tool => tool.data.popular)
        .slice(0, 3)
    : tools.slice(0, 3);

/* POPULAR PRODUCTS */

const popularProducts =
  products.filter(product => product.data.popular).length > 0
    ? products
        .filter(product => product.data.popular)
        .slice(0, 3)
    : products.slice(0, 3);

const pageTitle =
  'AI Mr Ferdy | Website Resmi Platform AI Indonesia';

const pageDescription =
  'Website resmi AI Mr Ferdy. Akses platform AI Indonesia untuk produktivitas digital, pembuatan konten, dan solusi otomatisasi modern.';
---

<MainLayout
  title={pageTitle}
  description={pageDescription}
  canonical={SITE.url()}
>


<section class="hero">
  <div class="hero-container">

    <div class="hero-content">
      <span class="hero-badge">
        AI MR FERDY
      </span>

      <h1>
        Analisis Pintar <br>
        <span>Dengan AI</span>
      </h1>

      <p>
        AI Mr Ferdy menggunakan algoritma cerdas untuk membaca pola,
        mengenali perubahan ritme, dan menghadirkan insight yang
        lebih cepat serta mudah dipahami.
      </p>

      <div class="hero-buttons">
        <a href="https://app.aimrferdy.workers.dev/" class="btn-primary">
          Mulai Sekarang
        </a>

        <a href="https://aimrferdy.com/blog/review-ai-mr-ferdy-real-2026-pengalaman/" class="btn-outline">
          Lihat Cara Kerja
        </a>
      </div>

      <div class="hero-features">
        <div class="feature">
          <p class="feature-title">Algoritma Cerdas</p>
          <p>Membaca pola secara otomatis.</p>
        </div>

        <div class="feature">
