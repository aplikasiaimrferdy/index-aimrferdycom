  </div>
<div class="hero-wave"></div>
</section>




  <!-- MAIN ECOSYSTEM -->
  <section class="section">
    <div class="container">

      <h2 class="section-title">
        AI Tools & Digital Ecosystem
      </h2>

      <p class="section-desc">
        Platform, tools dan website utama dalam ecosystem AI Mr Ferdy.
