<style is:global>
/* ====================================
   HERO AI MR FERDY
==================================== */

.hero{
  min-height:100vh;
  display:flex;
  align-items:center;
  position:relative;
  overflow:hidden;

  background:
    radial-gradient(
      circle at top right,
      rgba(59,130,246,.18),
      transparent 40%
    ),
    var(--bg);
}

/* GRID BACKGROUND */

.hero::before{
  content:"";
  position:absolute;
  inset:0;

  background-image:
    linear-gradient(var(--border) 1px, transparent 1px),
    linear-gradient(90deg,var(--border) 1px, transparent 1px);

  background-size:50px 50px;
  opacity:.3;
  pointer-events:none;
}

/* BLUE GLOW */

.hero-glow{
  position:absolute;
  top:-250px;
  right:-200px;

  width:700px;
  height:700px;

  background:
    radial-gradient(
      circle,
      rgba(0,140,255,.25),
      transparent 70%
    );

  filter:blur(80px);
  pointer-events:none;
}

/* CONTAINER */

.hero-container{
  width:min(1300px,92%);
  margin:auto;

  display:grid;
  grid-template-columns:1fr 1fr;
  gap:60px;
  align-items:center;

  position:relative;
  z-index:2;
}

/* TEXT */

.hero-badge{
  display:inline-block;
  color:#38bdf8;
  font-weight:700;
  letter-spacing:2px;
  text-transform:uppercase;
}

.hero-content h1{
  margin:20px 0;

  font-size:clamp(2.5rem,6vw,5rem);
  line-height:1.05;

  color:var(--text);
}

.hero-content h1 span{
  background:
    linear-gradient(
      90deg,
      #22d3ee,
      #3b82f6
    );

  -webkit-background-clip:text;
  -webkit-text-fill-color:transparent;
}

.hero-content p{
  max-width:620px;

  color:var(--soft);

  font-size:1.1rem;
  line-height:1.8;
}

/* BUTTONS */

.hero-buttons{
  display:flex;
  gap:16px;
  margin-top:32px;
}

.btn-primary{
  display:inline-flex;
  align-items:center;
  justify-content:center;

  padding:15px 30px;

  border-radius:14px;
  text-decoration:none;

  color:#fff;
  font-weight:600;

  background:
    linear-gradient(
      135deg,
      #06b6d4,
      #2563eb
    );

  box-shadow:
    0 15px 40px rgba(37,99,235,.25);
}

.btn-primary:hover{
  transform:translateY(-2px);
}

.btn-outline{
  display:inline-flex;
  align-items:center;
  justify-content:center;

  padding:15px 30px;

  border-radius:14px;
  text-decoration:none;

  border:1px solid var(--border);

  background:var(--card);

  color:var(--text);

  backdrop-filter:blur(12px);
}

/* IMAGE */

.hero-image{
  position:relative;
}

.glass-card{
  background:var(--card);

  border:1px solid var(--border);

  border-radius:30px;

  padding:40px;

  backdrop-filter:blur(20px);

  box-shadow:
    0 20px 80px rgba(0,0,0,.15);
}

.glass-card img{
  width:100%;
  display:block;
}

/* FLOATING INFO */

.floating-card{
  position:absolute;

  background:var(--card);

  border:1px solid var(--border);

  border-radius:16px;

  padding:16px 20px;

  color:var(--text);

  backdrop-filter:blur(20px);

  box-shadow:
    0 15px 40px rgba(0,0,0,.15);
}

.floating-card h4{
  margin:0 0 5px;
}

.floating-card p{
  margin:0;
  color:var(--soft);
  font-size:.9rem;
}

.floating-card.top{
  top:10%;
  left:-50px;
}

.floating-card.bottom{
  bottom:10%;
  right:-30px;
}

/* FEATURES */

.hero-features{
  display:flex;
  gap:20px;
  margin-top:50px;
}

.feature{
  flex:1;

  padding:20px;

  background:var(--card);

  border:1px solid var(--border);

  border-radius:18px;
}

.feature h3{
  margin-bottom:10px;
  color:var(--text);font-size:1.00rem;
}

.feature p{
  margin:0;
  color:var(--soft);
  font-size:.75rem;
}

/* PARTICLE WAVE */

.hero-wave{
  position:absolute;

  left:0;
  right:0;
  bottom:-80px;

  height:300px;

  pointer-events:none;
  z-index:1;
}

.hero-wave::before{
  content:"";
  position:absolute;
  inset:0;

  background:
    radial-gradient(
      circle,
      rgba(34,211,238,.9) 1px,
      transparent 2px
    );

  background-size:18px 18px;

  transform:
    perspective(800px)
    rotateX(75deg);

  opacity:.35;
}

/* MOBILE */

@media(max-width:900px){

  .hero{
    padding:80px 0;
  }

  .hero-container{
    grid-template-columns:1fr;
    text-align:center;
  }

  .hero-content p{
    margin:auto;
  }

  .hero-buttons{
    justify-content:center;
    flex-wrap:wrap;
  }

  .hero-features{
    flex-direction:column;
  }

  .floating-card{
    display:none;
  }

  .glass-card{
    padding:20px;
  }

  .hero-content h1{
    font-size:clamp(2rem,10vw,3rem);
  }
}


.price-image{
  display:block;

  overflow:hidden;

  margin-bottom:18px;

  border-radius:22px;

  border:1px solid var(--border);

  background:var(--card);
}

.price-image img{
  width:100%;
  height:auto;

  display:block;

  transition:transform .35s ease;
}

.price-card:hover .price-image img{
  transform:scale(1.03);
}

.feature-title {
    margin: 0 0 6px;
    font-size: 1.1rem;
    font-weight: 700;
    line-height: 1.3;
    color: #fff;
    letter-spacing: -.02em;
}
</style>


</MainLayout>
