---
import MainLayout from '../layouts/MainLayout.astro';
import { SITE } from '../lib/site';
import "../styles/blog.css";
import { getCollection } from 'astro:content';

let posts = await getCollection('blog');

const latestPosts = [...posts]
  .sort((a, b) => new Date(b.data.date) - new Date(a.data.date))
  .slice(0, 3);

const popularPosts = [...posts]
  .filter((post) => post.data.popular)
  .slice(0, 3);

const pageTitle =
  'AI Mr Ferdy | Website Resmi Platform AI Indonesia';

const pageDescription =
  'Website resmi AI Mr Ferdy. Akses platform AI Indonesia untuk produktivitas digital, pembuatan konten, dan solusi otomatisasi modern.';
---

<MainLayout
  title={pageTitle}
  description={pageDescription}
  canonical={SITE.url()}
>


<section class="hero">
  <div class="hero-container">

    <div class="hero-content">
      <span class="hero-badge">
        AI MR FERDY
      </span>

      <h1>
        Analisis Pintar <br>
        <span>Dengan AI</span>
      </h1>

      <p>
        AI Mr Ferdy menggunakan algoritma cerdas untuk membaca pola,
        mengenali perubahan ritme, dan menghadirkan insight yang
        lebih cepat serta mudah dipahami.
      </p>

      <div class="hero-buttons">
        <a href="#" class="btn-primary">
          Mulai Sekarang
        </a>

        <a href="#cara-kerja" class="btn-outline">
          Lihat Cara Kerja
        </a>
      </div>

      <div class="hero-features">
        <div class="feature">
          <h3>Algoritma Cerdas</h3>
          <p>Membaca pola secara otomatis.</p>
        </div>

        <div class="feature">
          <h3>Cepat & Efisien</h3>
          <p>Insight dalam hitungan detik.</p>
        </div>

        <div class="feature">
          <h3>Akurat</h3>
          <p>Analisis lebih konsisten.</p>
        </div>
      </div>

    </div>

    <div class="hero-image">

      <div class="glass-card">
        <img src="https://blogger.googleusercontent.com/img/b/R29vZ2xl/AVvXsEjmqxPP3dPcKCmXYMw92VfwhXPbzshecIeVInGtbwMoqEEBd-6OkP1wSG4iQE0nwms0WXvDOGPovV_8X-_Slcik6NiGp9VHQ8jiEEyRa44GUzK6UN97kpHaNz8HuMFo7HKX0-md2i7xt19uEL_AyE8blirHtF9BtenkOoVQYuR2ghIyEfm6xWHuB9vBP5QI/s0/aimrferdy.png" alt="AI Mr Ferdy">
      </div>

      <div class="floating-card top">
        <h4>Pola Terdeteksi</h4>
        <p>Aktivitas Stabil</p>
      </div>

      <div class="floating-card bottom">
        <h4>Insight Siap</h4>
        <p>Analisis Selesai</p>
      </div>

    </div>
<div class="hero-wave"></div>

  </div>
</section>







<style>
.hero {
  min-height: 100vh;
  display: flex;
  align-items: center;
  background:
    radial-gradient(circle at top right,
      rgba(0,120,255,.25),
      transparent 40%),
    #020617;
  overflow: hidden;
  position: relative;
}

.hero::before {
  content: "";
  position: absolute;
  inset: 0;
  background:
    url("");
  opacity: .05;
}

.hero-container {
  width: min(1300px, 92%);
  margin: auto;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 60px;
  align-items: center;
}

.hero-badge {
  color: #38bdf8;
  font-weight: 700;
  letter-spacing: 2px;
  text-transform: uppercase;
}

.hero-content h1 {
  font-size: clamp(1rem, 5vw, 4rem);
  line-height: 1;
  color: #fff;
  margin: 20px 0;
}

.hero-content h1 span {
  background: linear-gradient(
    90deg,
    #00d4ff,
    #3b82f6
  );
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.hero-content p {
  color: #cbd5e1;
  font-size: 1.2rem;
  line-height: 1.8;
  max-width: 600px;
}

.hero-buttons {
  display: flex;
  gap: 20px;
  margin-top: 40px;
}

.btn-primary {
  background: linear-gradient(
    135deg,
    #00d4ff,
    #2563eb
  );
  color: white;
  padding: 15px 30px;
  border-radius: 14px;
  text-decoration: none;
  font-weight: 600;
}

.btn-outline {
  border: 1px solid #3b82f6;
  color: white;
  padding: 15px 30px;
  border-radius: 14px;
  text-decoration: none;
}

.hero-image {
  position: relative;
}

.glass-card {
  background: rgba(255,255,255,.05);
  border: 1px solid rgba(255,255,255,.1);
  backdrop-filter: blur(20px);
  border-radius: 30px;
  padding: 40px;
}

.glass-card img {
  width: 100%;
  display: block;
}

.floating-card {
  position: absolute;
  background: rgba(8,15,35,.95);
  border: 1px solid rgba(0,212,255,.3);
  backdrop-filter: blur(10px);
  border-radius: 15px;
  padding: 15px 20px;
  color: white;
  box-shadow:
    0 0 20px rgba(0,212,255,.15);
}

.floating-card.top {
  top: 10%;
  left: -50px;
}

.floating-card.bottom {
  bottom: 10%;
  right: -30px;
}

.hero-features {
  display: flex;
  gap: 20px;
  margin-top: 60px;
}

.feature {
  flex: 1;
  padding: 20px;
  background: rgba(255,255,255,.04);
  border-radius: 18px;
}

.feature h3 {
  color: #fff;
  margin-bottom: 10px;
}

.feature p {
  font-size: .95rem;
  color: #94a3b8;
}

@media (max-width: 900px) {

  .hero-container {
    grid-template-columns: 1fr;
    text-align: center;
  }

  .hero-features {
    flex-direction: column;
  }

  .hero-buttons {
    justify-content: center;
  }

  .floating-card {
    display: none;
  }
}


.hero-wave {
  position: absolute;
  bottom: 0;
  width: 100%;
  height: 250px;
  background:
    radial-gradient(
      circle,
      rgba(0,212,255,.5) 1px,
      transparent 1px
    );
  background-size: 20px 20px;
  opacity: .2;
}
</style>


  <!-- HERO -->
  <section class="hero">
    <div class="container">

      <div class="hero-grid">

        <div class="hero-left">

          <div class="hero-tag">
            AI • SEO • AUTOMATION
          </div>

          <h1>
            AI Mr Ferdy
          </h1>

          <p>
            Website resmi AI Mr Ferdy. Akses platform AI Indonesia untuk produktivitas digital, pembuatan konten, dan solusi otomatisasi modern.
          </p>

          <div class="hero-btns">

            <a
              href="https://aimrferdy.com"
              class="btn btn-primary"
            >
              Official Website
            </a>

            <a
              href="https://news.aimrferdy.com"
              class="btn btn-secondary"
            >
              Latest Articles
            </a>

          </div>

        </div>

        <div class="hero-right">

          <div class="hero-card">

            <div class="hero-badge">
              AI SYSTEMS
            </div>

            <h3>
              Modern AI Solutions
            </h3>

            <p>
              AI tools, smart automation dan digital workflow modern
              untuk produktivitas dan bisnis online.
            </p>

          </div>

          <div class="hero-card">

            <div class="hero-badge">
              SEO PERFORMANCE
            </div>

            <h3>
              Fast & Optimized
            </h3>

            <p>
              Website ultra cepat, mobile first dan optimized
              untuk modern search engine.
            </p>

          </div>

        </div>

      </div>

    </div>
  </section>

  <!-- MAIN ECOSYSTEM -->
  <section class="section">
    <div class="container">

      <h2 class="section-title">
        AI Tools & Digital Ecosystem
      </h2>

      <p class="section-desc">
        Platform, tools dan website utama dalam ecosystem AI Mr Ferdy.
      </p>

      <div class="pricing">

        <div class="price-card">

          <h3>
            Official Website
          </h3>

          <p>
            Website utama AI Mr Ferdy untuk platform digital modern.
          </p>

          <a
            href="https://aimrferdy.com"
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn-primary"
          >
            Visit Website
          </a>

        </div>

        <div class="price-card">

          <h3>
            News & Articles
          </h3>

          <p>
            Artikel AI, SEO, automation dan teknologi modern terbaru.
          </p>

          <a
            href="https://aimrferdy.com/blog"
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn-primary"
          >
            Open News
          </a>

        </div>

        <div class="price-card">

          <h3>
            AI Tools
          </h3>

          <p>
            Tools digital modern, utility online dan automation systems.
          </p>

          <a
            href="https://aimrferdy.com/tools"
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn-primary"
          >
            Open Tools
          </a>

        </div>

      </div>

    </div>
  </section>

  <!-- SERVICES -->
  <section class="section">
    <div class="container">

      <h2 class="section-title">
        AI & Digital Services
      </h2>

      <p class="section-desc">
        AI Mr Ferdy adalah platform berbasis kecerdasan buatan (AI) Fokus pada AI systems yang dirancang untuk memenuhi berbagai kebutuhan digital, mulai dari pembuatan situs web, program kreatif, hingga peningkatan digital platform modern secara praktis.
      </p>

      <div class="features">

        <div class="feature-card">

          <h3>
            AI Projects
          </h3>

          <p>
            AI applications, smart systems dan automation workflow modern.
          </p>

        </div>

        <div class="feature-card">

          <h3>
            SEO Systems
          </h3>

          <p>
            Website optimized, scalable dan search engine friendly.
          </p>

        </div>

        <div class="feature-card">

          <h3>
            Modern UI
          </h3>

          <p>
            Clean interface, ultra fast performance dan mobile first design.
          </p>

        </div>

      </div>

    </div>
  </section>

  <!-- LATEST ARTICLES -->
<!-- LATEST ARTICLES -->
<section class="section">

  <div class="container">

    <h2 class="section-title">
      Latest AI Articles
    </h2>

    <p class="section-desc">
      Artikel terbaru tentang AI, SEO dan teknologi modern.
    </p>

    <div class="blog-grid">

      {
        latestPosts.map((post) => (

          <article class="blog-card">

            <a
              href={`/blog/${post.slug}/`}
              class="blog-card-link"
            >

              <div class="blog-card-image">

                <img
                  src={SITE.url(`/api/og/${post.slug}.svg`)}
                  alt={post.data.title}
                  loading="lazy"
                  width="1200"
                  height="630"
                />

              </div>

              <div class="blog-card-content">

                <div class="blog-card-meta">
                  {post.data.date}
                </div>

                <h2>
                  {post.data.title}
                </h2>

                {post.data.description && (
                  <p>
                    {post.data.description}
                  </p>
                )}

                <span class="readmore">
                  Read Article →
                </span>

              </div>

            </a>

          </article>

        ))
      }

    </div>

  </div>

</section>

<!-- POPULAR GUIDES -->
<section class="section">

  <div class="container">

    <h2 class="section-title">
      Popular SEO & AI Guides
    </h2>

    <p class="section-desc">
      Artikel populer dalam ecosystem AI Mr Ferdy.
    </p>

    <div class="blog-grid">

      {
        popularPosts.map((post) => (

          <article class="blog-card">

            <a
              href={`/blog/${post.slug}/`}
              class="blog-card-link"
            >

              <div class="blog-card-image">

                <img
                  src={SITE.url(`/api/og/${post.slug}.svg`)}
                  alt={post.data.title}
                  loading="lazy"
                  width="1200"
                  height="630"
                />

              </div>

              <div class="blog-card-content">

                <div class="blog-card-meta">
                  {post.data.date}
                </div>

                <h2>
                  {post.data.title}
                </h2>

                {post.data.description && (
                  <p>
                    {post.data.description}
                  </p>
                )}

                <span class="readmore">
                  Read Guide →
                </span>

