    </div>

  </div>

</section>



<!-- POPULAR PRODUCTS -->
<section class="section">

  <div class="container">

    <h2 class="section-title">
      Popular AI Products
    </h2>

    <p class="section-desc">
      Produk digital populer dari AI Mr Ferdy.
    </p>

    <div class="blog-grid">

      {
        popularProducts.map((product) => (

          <article class="blog-card">

            <a
              href={`/product/${product.slug}/`}
