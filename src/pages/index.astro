                    {product.data.price}
                  </div>
                )}

                <span class="readmore">
                  View Product →
                </span>

              </div>

            </a>

          </article>

        ))
      }

    </div>

  </div>

</section>


<!-- POPULAR GUIDES -->
<section class="section">

  <div class="container">

    <h2 class="section-title">
      Popular SEO & AI Guides
    </h2>

    <p class="section-desc">
      Artikel populer dalam ecosystem AI Mr Ferdy.
    </p>

    <div class="blog-grid">

      {
        popularPosts.map((post) => (

          <article class="blog-card">

            <a
              href={`/blog/${post.slug}/`}
              class="blog-card-link"
            >

              <div class="blog-card-image">

                <img
                  src={SITE.url(`/api/og/${post.slug}.svg`)}
