  <!-- LATEST ARTICLES -->
<!-- LATEST ARTICLES -->
<section class="section">

  <div class="container">

    <h2 class="section-title">
      Latest AI Articles
    </h2>

    <p class="section-desc">
      Artikel terbaru tentang AI, SEO dan teknologi modern.
    </p>

    <div class="blog-grid">

      {
        latestPosts.map((post) => (

          <article class="blog-card">

            <a
              href={`/blog/${post.slug}/`}
              class="blog-card-link"
            >

              <div class="blog-card-image">

                <img
                  src={SITE.url(`/api/og/${post.slug}.svg`)}
                  alt={post.data.title}
                  loading="lazy"
                  width="1200"
                  height="630"
                />

              </div>

              <div class="blog-card-content">

                <div class="blog-card-meta">
                  {post.data.date}
                </div>

                <h2>
                  {post.data.title}
                </h2>

                {post.data.description && (
                  <p>
                    {post.data.description}
