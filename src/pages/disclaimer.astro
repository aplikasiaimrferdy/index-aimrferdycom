</MainLayout>

<style>
  :global(:root) {
    --bg: #0f172a;
    --card: #111827;
    --soft: #1e293b;
    --border: rgba(255,255,255,.08);
    --text: #f8fafc;
    --muted: #94a3b8;
    --primary: #3b82f6;
    --radius: 24px;
    --container: 920px;
  }

  section {
    padding: 90px 20px;
  }

  .container {
    width: 100%;
    max-width: var(--container);
    margin: auto;
  }

  .hero {
    padding-top: 120px;
    padding-bottom: 70px;
    text-align: center;
  }

  .hero-content {
    max-width: 760px;
  }

  .badge {
    display: inline-flex;
    padding: 10px 18px;
    border-radius: 999px;
    background: rgba(59,130,246,.12);
    border: 1px solid rgba(59,130,246,.25);
    color: #93c5fd;
    font-size: 14px;
    font-weight: 700;
  }

  .hero h1 {
    font-size: clamp(42px, 7vw, 68px);
    line-height: 1.1;
    margin: 24px 0;
  }

  .hero p {
    color: var(--muted);
    font-size: 18px;
    line-height: 1.8;
  }

  .content-card {
    background: rgba(255,255,255,.03);
    border: 1px solid var(--border);
    border-radius: 32px;
    padding: 50px;
  }

  .content-block + .content-block {
    margin-top: 50px;
    padding-top: 50px;
    border-top: 1px solid rgba(255,255,255,.06);
  }

  .content-block h2 {
    font-size: 30px;
    margin-bottom: 18px;
    line-height: 1.2;
  }

  .content-block p {
    color: var(--muted);
    line-height: 1.9;
    margin-bottom: 18px;
    font-size: 16px;
  }

  ul {
    margin: 20px 0;
    padding-left: 20px;
    color: var(--muted);
  }

  li {
    margin-bottom: 12px;
    line-height: 1.8;
  }

  @media (max-width: 768px) {
    section {
      padding: 70px 20px;
    }

    .hero {
      padding-top: 90px;
      padding-bottom: 40px;
    }

    .hero h1 {
      font-size: 42px;
    }

    .content-card {
      padding: 30px 24px;
      border-radius: 24px;
    }

    .content-block + .content-block {
      margin-top: 40px;
      padding-top: 40px;
    }

    .content-block h2 {
      font-size: 24px;
    }
  }
</style>
