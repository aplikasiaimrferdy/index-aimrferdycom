---
import ProductLayout from '../../layouts/ProductLayout.astro';

import { getCollection } from 'astro:content';

const products = await getCollection('product');

const featuredProducts = products
  .filter(product => product.data.featured)
  .map(product => ({
    ...product,
    displayImage:
      product.data.image?.trim()
      || `/api/og/${product.slug}.svg`
  }));
---


<ProductLayout
  title="Products | AI PRINT"
  description="Browse premium POD marketplace products."
>

<section class="hero">

  <div class="hero-content">

    <span class="badge">
      PREMIUM POD MARKETPLACE
    </span>

    <h1>
      Discover Modern
      <br />
      Print-On-Demand Designs
    </h1>

    <p>
      Ultra fast Astro ecommerce storefront with
      modern UI, responsive layouts, and SEO
      optimized architecture.
    </p>

  </div>

</section>

<section class="products-section">

  <div class="section-head">

    <div>

      <h2>
        Featured Products
      </h2>

      <p>
        Trending marketplace designs
      </p>

    </div>

    <div class="filters">

      <button class="active">
        Trending
      </button>

      <button>
        Latest
      </button>

      <button>
        Popular
      </button>

    </div>

  </div>

  <div class="products-grid">

    {
      featuredProducts.map(product => (

        <a
          href={`/product/${product.slug}`}
          class="card"
        >

          <div class="card-image">

<img
  src={product.displayImage}
  alt={product.data.title}
  loading="lazy"
/>

          </div>

          <div class="card-body">

            <div class="card-top">

              <span class="tag">
                FEATURED
              </span>

              <span class="category">
                {product.data.category}
              </span>

            </div>

            <h2>
              {product.data.title}
            </h2>

            <p class="desc">
              {product.data.description}
            </p>

            <div class="price-wrap">

              <span class="price">
                {product.data.price}
              </span>

              {
                product.data.oldPrice && (
                  <span class="old-price">
                    {product.data.oldPrice}
                  </span>
                )
              }

            </div>

          </div>

        </a>

      ))
    }

  </div>

</section>

<style>
.hero{
  position:relative;

  overflow:hidden;

  border-radius:40px;

  padding:90px 50px;

  margin-bottom:60px;

  background:
    linear-gradient(
      135deg,
      #111827,
      #1e293b
    );

  color:#fff;
}

.hero::before{
  content:"";

  position:absolute;

  inset:0;

  background:
    radial-gradient(
      circle at top right,
      rgba(88,101,242,.35),
      transparent 35%
    );
}

.hero-content{
  position:relative;

  z-index:2;

  max-width:720px;
}

.badge{
  display:inline-flex;

  padding:10px 16px;

  border-radius:999px;

  background:
    rgba(255,255,255,.12);

  border:
    1px solid rgba(255,255,255,.15);

  font-size:13px;

  font-weight:800;

  margin-bottom:20px;
}

.hero h1{
  font-size:68px;

  line-height:1;

  margin-bottom:24px;
}

.hero p{
  font-size:18px;

  line-height:1.9;

  color:#d1d5db;
}

.products-section{
  margin-top:30px;
}

.section-head{
  display:flex;

  align-items:center;

  justify-content:space-between;

  gap:20px;

  margin-bottom:34px;
}

.section-head h2{
  font-size:42px;

  margin-bottom:6px;
}

.section-head p{
  color:#6b7280;
}

.filters{
  display:flex;

  flex-wrap:wrap;

  gap:12px;
}

.filters button{
  border:none;

  background:#fff;

  padding:12px 18px;

  border-radius:14px;

  font-weight:700;

  cursor:pointer;

  box-shadow:var(--shadow);
}

.filters .active{
  background:var(--dark);

  color:#fff;
}

.products-grid{
  display:grid;

  grid-template-columns:
    repeat(4,1fr);

  gap:24px;
}

.card{
  background:#fff;

  border-radius:30px;

  overflow:hidden;

  box-shadow:var(--shadow);

  transition:.25s;
}

.card:hover{
  transform:
    translateY(-6px);
}

.card-image{
  overflow:hidden;
}

.card-image img{
  width:100%;

  height:360px;

  object-fit:cover;

  transition:.4s;
}

.card:hover img{
  transform:scale(1.05);
}

.card-body{
  padding:22px;
}

.card-top{
  display:flex;

  align-items:center;

  justify-content:space-between;

  gap:10px;

  margin-bottom:14px;
}

.tag{
  display:inline-flex;

  background:#eef2ff;

  color:#4338ca;

  padding:8px 12px;

  border-radius:999px;

  font-size:12px;

  font-weight:800;
}

.category{
  color:#6b7280;

  font-size:13px;

  font-weight:700;
}

.card h2{
  font-size:22px;

  line-height:1.3;

  margin-bottom:12px;
}

.desc{
  color:#6b7280;

  line-height:1.8;

  margin-bottom:18px;

  font-size:15px;
}

.price-wrap{
  display:flex;

  align-items:center;

  gap:12px;
}

.price{
  font-size:28px;

  font-weight:900;
}

.old-price{
  color:#9ca3af;

  text-decoration:line-through;
}

@media(max-width:1200px){

  .products-grid{
    grid-template-columns:
      repeat(2,1fr);
  }

  .hero h1{
    font-size:54px;
  }

}

@media(max-width:768px){

  .hero{
    padding:60px 24px;
  }

  .hero h1{
    font-size:40px;
  }

  .hero p{
    font-size:16px;
  }

  .section-head{
    flex-direction:column;

    align-items:flex-start;
  }

  .section-head h2{
    font-size:34px;
  }

  .products-grid{
    grid-template-columns:1fr;
  }

  .card-image img{
    height:320px;
  }

}
</style>

</ProductLayout>
