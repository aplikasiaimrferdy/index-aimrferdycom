---
import ProductLayout from '../../layouts/ProductLayout.astro';
import RelatedPosts from '../../components/RelatedPosts.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const products = await getCollection('product');

  return products.map((product) => ({
    params: {
      slug: product.slug
    },
    props: {
      product
    }
  }));
}

const { product } = Astro.props;

const { Content } = await product.render();

const relatedProducts = (await getCollection('product'))
  .filter(
    (p) =>
      p.slug !== product.slug &&
      p.data.category === product.data.category
  )
  .slice(0, 6);

const productImage =
  product.data.image?.trim()
  || `/api/og/${product.slug}.svg`;

const galleryImages =
  product.data.gallery?.filter(img => img?.trim()).length
    ? product.data.gallery.filter(img => img?.trim())
    : [productImage];

---

<ProductLayout
  title={`${product.data.title} | AI PRINT`}
  description={product.data.description}
  slug={product.slug}
  product={product.data}
>

<section class="product-layout">

  <aside class="gallery">

  {
    galleryImages.map((img, index) => (

      <div
        class={`thumb ${index === 0 ? 'active' : ''}`}
      >

        <img
          src={img}
          alt={product.data.title}
        />

      </div>

    ))
  }

</aside>

  <section class="preview">
<img
  id="mainImage"
  src={productImage}
  alt={product.data.title}
/>


  </section>

  <aside class="product-info">

    <h1>
      {product.data.title}
    </h1>

    <div class="seller">
      Designed and sold by AI PRINT
    </div>

    <div class="price-wrap">

      <div class="price">
        {product.data.price}
      </div>

      {
        product.data.oldPrice && (
          <div class="old-price">
            {product.data.oldPrice}
          </div>
        )
      }

    </div>

    <div class="label">
      Category
    </div>

    <div class="options">
      <button class="active-btn">
        {product.data.category}
      </button>
    </div>

    <div class="label">
      Size
    </div>

    <div class="options">
      <button>S</button>
      <button>M</button>
      <button class="active-btn">L</button>
      <button>XL</button>
      <button>2XL</button>
    </div>

    <button class="cart-btn">
      ADD TO CART
    </button>

  </aside>

</section>

<section class="description-section">

  <div class="description-box">

    <article class="content">
      <Content />
    </article>

  </div>

</section>

{
  relatedProducts.length > 0 && (
    <section class="related-section">

      <RelatedPosts
        posts={relatedProducts}
        title="Produk Terkait"
        baseUrl="/product"
      />

    </section>
  )
}






<style is:global>
.product-layout{
display:grid;
grid-template-columns:110px minmax(0,1fr) 420px;
gap:30px;
align-items:start;
}

/* =========================
   GALLERY
========================= */

.gallery{
display:flex;
flex-direction:column;
gap:14px;
}

.thumb{
background:#fff;
padding:6px;
border-radius:22px;
border:2px solid transparent;
box-shadow:var(--shadow);
cursor:pointer;
transition:.25s;
overflow:hidden;
}

.thumb img{
width:100%;
display:block;
border-radius:16px;
aspect-ratio:1/1;
object-fit:cover;
}

.thumb:hover{
transform:translateY(-3px);
}

.thumb.active{
border-color:var(--primary);
}

/* =========================
   CARD BOXES
========================= */

.preview,
.product-info,
.description-box{
background:#fff;
border-radius:32px;
box-shadow:var(--shadow);
}

/* =========================
   PREVIEW IMAGE
========================= */

.preview{
padding:40px;
display:flex;
align-items:center;
justify-content:center;

aspect-ratio:1/1;

overflow:hidden;
position:relative;
}

.preview img{
width:100%;
height:100%;
object-fit:contain;
display:block;
transition:.3s;
}

/* =========================
   PRODUCT INFO
========================= */

.product-info{
padding:34px;
position:sticky;
top:110px;
}

.product-info h1{
font-size:38px;
line-height:1.1;
}

.seller{
margin-top:10px;
color:var(--muted);
}

.price-wrap{
display:flex;
align-items:center;
gap:14px;
margin:24px 0;
}

.price{
font-size:48px;
font-weight:900;
line-height:1;
}

.old-price{
text-decoration:line-through;
color:#999;
}

/* =========================
   OPTIONS
========================= */

.label{
margin:28px 0 12px;
font-weight:700;
}

.options{
display:flex;
flex-wrap:wrap;
gap:10px;
}

.options button{
padding:12px 18px;
border-radius:14px;
border:1px solid var(--border);
background:#fff;
cursor:pointer;
transition:.2s;
}

.options button:hover{
border-color:var(--primary);
}

.active-btn{
background:var(--dark)!important;
color:#fff;
border-color:var(--dark)!important;
}

/* =========================
   BUTTON
========================= */

.cart-btn{
width:100%;
margin-top:30px;
padding:18px;
border:none;
border-radius:18px;
background:
linear-gradient(
135deg,
#5865f2,
#7c3aed
);

color:#fff;
font-size:18px;
font-weight:900;
cursor:pointer;
transition:.25s;
}

.cart-btn:hover{
transform:translateY(-2px);
}

/* =========================
   DESCRIPTION
========================= */

.description-section{
margin-top:60px;
}

.description-box{
padding:40px;
line-height:1.9;
color:#555;
overflow:hidden;
}

.content h1,
.content h2,
.content h3{
margin-bottom:18px;
color:var(--dark);
line-height:1.3;
}

.content p{
margin-bottom:18px;
}

.content ul{
padding-left:22px;
margin-bottom:18px;
}

/* =========================
   TABLET
========================= */

@media(max-width:1200px){

.product-layout{
grid-template-columns:1fr;
}

.gallery{
flex-direction:row;
overflow:auto;
padding-bottom:4px;
}

.gallery::-webkit-scrollbar{
display:none;
}

.thumb{
min-width:90px;
}

.product-info{
position:relative;
top:0;
}

}

/* =========================
   MOBILE
========================= */

@media(max-width:768px){

.product-layout{
gap:20px;
}

.preview{
padding:20px;
border-radius:24px;
}

.product-info{
padding:24px;
border-radius:24px;
}

.description-box{
padding:24px;
border-radius:24px;
}

.product-info h1{
font-size:30px;
}

.price{
font-size:38px;
}

.options{
gap:8px;
}

.options button{
padding:10px 14px;
font-size:14px;
}

.cart-btn{
padding:16px;
font-size:16px;
}

}




.content ul{
  list-style:none;
  padding-left:20px;
  margin:20px 0;
}

.content li{
  position:relative;
  padding-left:28px;
  margin-bottom:12px;
  line-height:1.7;
}

.content li::before{
  content:"✓";
  position:absolute;
  left:0;
  top:0;
  color:var(--main-color,#7fff00);
  font-weight:700;
}
</style>


<script is:global>
const thumbs=document.querySelectorAll('.thumb');
const mainImage=document.getElementById('mainImage');

thumbs.forEach(thumb=>{
  thumb.addEventListener('click',()=>{
    thumbs.forEach(t=>t.classList.remove('active'));

    thumb.classList.add('active');

    mainImage.src=
      thumb.querySelector('img').src;
  });
});
</script>
</ProductLayout>
