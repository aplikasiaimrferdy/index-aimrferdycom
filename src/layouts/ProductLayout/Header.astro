<header class="navbar">

  <a href="/" class="logo">
    AI MR FERDY
  </a>

  <form
    class="search"
    id="searchForm"
  >

    <input
      type="text"
      id="searchInput"
      placeholder="Search products..."
    />

    <button type="submit">
      Search
    </button>

  </form>

  <nav
    class="nav-links"
    id="mobileMenu"
  >

    <a href="/product">
      Explore
    </a>

    <a href="/account">
      Account
    </a>

    <a href="/cart">
      Cart
    </a>

  </nav>

  <button
    class="menu-btn"
    id="menuBtn"
    aria-label="Menu"
  >

    ☰

  </button>

</header>

<style>

/* =========================
   NAVBAR
========================= */

.navbar{
position:sticky;
top:0;
z-index:9999;

display:flex;
align-items:center;
justify-content:space-between;
gap:20px;

padding:18px 24px;

background:
rgba(17,24,39,.92);

backdrop-filter:
blur(14px);

border-bottom:
1px solid rgba(255,255,255,.06);
}

/* =========================
   LOGO
========================= */

.logo{
font-size:30px;
font-weight:900;
color:#fff;
}

/* =========================
   SEARCH
========================= */

.search{
flex:1;

display:flex;

max-width:700px;

background:
rgba(255,255,255,.08);

border-radius:16px;

overflow:hidden;
}

.search input{
flex:1;

height:56px;

padding:0 18px;

background:transparent;

border:none;
outline:none;

color:#fff;
}

.search button{
border:none;

padding:0 22px;

background:
linear-gradient(
135deg,
#5865f2,
#7c3aed
);

color:#fff;

font-weight:700;

cursor:pointer;
}

/* =========================
   NAVIGATION
========================= */

.nav-links{
display:flex;
align-items:center;
gap:12px;
}

.nav-links a{
padding:12px 16px;

border-radius:12px;

color:#fff;

font-weight:700;

transition:.2s;
}

.nav-links a:hover{
background:
rgba(255,255,255,.08);
}

/* =========================
   MOBILE BUTTON
========================= */

.menu-btn{
display:none;

width:52px;
height:52px;

border:none;

border-radius:14px;

background:
rgba(255,255,255,.08);

color:#fff;

font-size:24px;

cursor:pointer;
}

/* =========================
   MOBILE
========================= */

@media(max-width:900px){

.menu-btn{
display:flex;
align-items:center;
justify-content:center;
}

.search{
order:3;
width:100%;
max-width:none;
}

.navbar{
flex-wrap:wrap;
}

/* MOBILE MENU */

.nav-links{
position:absolute;

top:100%;

left:0;
right:0;

display:none;

flex-direction:column;
align-items:flex-start;

padding:18px;

background:#111827;

border-bottom:
1px solid rgba(255,255,255,.06);
}

.nav-links.active{
display:flex;
}

.nav-links a{
width:100%;
}

}

</style>

<script>

/* =========================
   SEARCH
========================= */

const form =
  document.getElementById(
    'searchForm'
  );

const input =
  document.getElementById(
    'searchInput'
  );

form?.addEventListener(
  'submit',
  e => {

    e.preventDefault();

    const value =
      input.value.trim();

    if (!value) return;

    window.location.href =
      `/searchresult/?q=${
        encodeURIComponent(value)
      }&type=product`;

  }
);

/* =========================
   MOBILE MENU
========================= */

const menuBtn =
  document.getElementById(
    'menuBtn'
  );

const mobileMenu =
  document.getElementById(
    'mobileMenu'
  );

menuBtn?.addEventListener(
  'click',
  ()=>{

    mobileMenu.classList.toggle(
      'active'
    );

  }
);

</script>
