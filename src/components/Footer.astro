<style>
/* =========================
   FOOTER
========================= */

footer{
  margin-top:80px;
  padding:40px 20px;

  border-top:1px solid var(--border);

  text-align:left;
  color:var(--muted);

  font-size:14px;
}

/* =========================
   FOOTER MODERN
========================= */

.footer-modern{
  padding:80px 0 26px;

  border-top:1px solid var(--border);

  /* FIX LIGHT/DARK */
  background:var(--bg-secondary);

  overflow:hidden;
}

/* =========================
   CONTAINER
========================= */

.footer-modern .container{
  width:100%;
  max-width:1200px;

  margin:auto;
  padding:0 20px;

  box-sizing:border-box;
}

/* =========================
   GRID LAYOUT
========================= */

.footer-grid{
  display:grid;

  /* Latest | Popular | Service | About */
  grid-template-columns:
    minmax(0, 1.4fr)
    minmax(0, 1.4fr)
    minmax(0, 0.6fr)
    minmax(0, 1.3fr);

  gap:40px;

  width:100%;
  align-items:flex-start;
}

/* IMPORTANT FIX */
.footer-grid > *{
  min-width:0;
}

/* =========================
   ABOUT
========================= */

.footer-about h3{
  font-size:18px;
  line-height:1.2;

  letter-spacing:1px;
  margin-bottom:20px;

  color:var(--text);

  word-break:break-word;
}

.footer-about p{
  color:var(--text-soft);

  font-size:15px;
  line-height:1.9;

  margin-bottom:16px;

  overflow-wrap:break-word;
}

/* =========================
   TITLES
========================= */

.footer-service h4,
.footer-links h4{
  font-size:18px;
  margin-bottom:18px;

  color:var(--text);

  line-height:1.3;
}

.footer-service h4:not(:first-child){
  margin-top:28px;
}

/* =========================
   LINKS
========================= */

.footer-service a,
.footer-links a{
  display:block;

  color:var(--text-soft);
  text-decoration:none;

  font-size:15px;
  line-height:1.7;

  overflow-wrap:break-word;
  word-break:break-word;

  transition:
    transform .2s ease,
    opacity .2s ease,
    color .2s ease;
}

/* company/social spacing */

.footer-service a{
  margin-bottom:10px;
}

/* latest/popular spacing */

.footer-links{
  display:flex;
  flex-direction:column;
}

.footer-links a{
  margin-bottom:16px;

  display:-webkit-box;
  -webkit-line-clamp:2;
  -webkit-box-orient:vertical;

  overflow:hidden;
  text-overflow:ellipsis;
}

/* hover */

.footer-service a:hover,
.footer-links a:hover{
  color:var(--text);

  opacity:1;

  transform:translateX(4px);
}

/* =========================
   FOOTER BOTTOM
========================= */

.footer-bottom{
  margin-top:70px;
  padding-top:26px;

  border-top:1px solid var(--border);

  text-align:center;

  color:var(--text-soft);
  font-size:14px;
}

/* =========================
   TABLET
========================= */

@media(max-width:1024px){

  .footer-grid{
    grid-template-columns:1fr 1fr;
    gap:42px 28px;
  }

  .footer-about{
    grid-column:1/-1;
  }

}

/* =========================
   SERVICE
========================= */

.footer-service{
  display:block;
}

/* =========================
   MOBILE SERVICE GRID
========================= */

@media(max-width:640px){

  .footer-service{
    display:grid;
    grid-template-columns:1fr 1fr;
    gap:24px;
  }

  .footer-col h4{
    margin-bottom:14px;
  }

  .footer-col a{
    font-size:14px;
    margin-bottom:10px;
  }

}

/* =========================
   MOBILE
========================= */

@media(max-width:640px){

  .footer-modern{
    padding:60px 0 24px;
  }

  .footer-modern .container{
    padding:0 18px;
  }

  .footer-grid{
    grid-template-columns:1fr;
    gap:36px;
  }

  .footer-about h3{
    font-size:28px;
  }

  .footer-about p{
    font-size:14px;
    line-height:1.8;
  }

  .footer-service h4,
  .footer-links h4{
    font-size:17px;
    margin-bottom:16px;
  }

  .footer-service a,
  .footer-links a{
    font-size:14px;
  }

  .footer-bottom{
    margin-top:50px;
    font-size:13px;
  }

}










.footer-social {
  display: flex;
  justify-content: center;
  gap: 1rem;
  margin-bottom: 1rem;
}

.footer-social a {
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-color, #94a3b8);
  transition: all .2s ease;
}

.footer-social a:hover {
  color: var(--accent-color, #3b82f6);
  transform: translateY(-2px);
}
</style>

