---
const {
  posts = [],
  title = "Konten Terkait",
  baseUrl = ""
} = Astro.props;

const isTools = baseUrl === "/tools";

---

{
  posts.length > 0 && (
    <section class="related-posts">

      <h2>{title}</h2>

      <div class="related-grid">

        {posts.map((post) => (

          <article class="related-card">

            <a href={`${baseUrl}/${post.slug}/`}>
{!isTools && (
              <img
                src={
                  post.data.image
                    ? post.data.image
                    : `/api/og/${post.slug}.svg`
                }
                alt={post.data.title}
                loading="lazy"
              />
)}
              <h3>{post.data.title}</h3>

              {post.data.description && (
                <p>{post.data.description}</p>
              )}

            </a>

          </article>

        ))}

      </div>

    </section>
  )
}

<style is:global>
.related-posts{
  margin-top:50px;
}

.related-posts h2{
  font-size:24px;
  margin-bottom:20px;
}

.related-grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(240px,1fr));
  gap:20px;
}

.related-card{
  background:var(--card);
  border:1px solid var(--border);
  border-radius:18px;
  overflow:hidden;
  transition:.2s;
  box-shadow:var(--shadow);
}

.related-card:hover{
  transform:translateY(-3px);
}

.related-card a{
  display:block;
  color:inherit;
  text-decoration:none;
}

.related-card img{
  width:100%;
  aspect-ratio:1200/630;
  object-fit:cover;
  display:block;
}

.related-card h3{
  font-size:16px;
  line-height:1.5;
  padding:14px 16px 6px;
  margin:0;
}

.related-card p{
  font-size:14px;
  color:var(--muted);
  padding:0 16px 16px;
  margin:0;
  line-height:1.6;
}

@media (max-width:768px){
  .related-grid{
    grid-template-columns:repeat(2,1fr);
    gap:12px;
  }

  .related-card h3{
    font-size:14px;
    padding:10px 12px 4px;
  }

  .related-card p{
    font-size:12px;
    padding:0 12px 12px;
  }
}
</style>
